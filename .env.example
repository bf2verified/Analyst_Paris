# --- AI API ---
# Priorité: Groq (gratuit, rapide) > Claude (payant, plus poussé)

# Groq (RECOMMANDÉ pour démarrer — gratuit): https://console.groq.com/keys
GROQ_API_KEY=

# Claude / Anthropic (payant): https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Données football ---
# Gratuit (10 req/min): https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# Freemium (plus de marchés: corners, cartons): https://www.api-football.com/
API_FOOTBALL_KEY=

# --- Flask ---
FLASK_ENV=development
PORT=5000
